APP_ENV=prod
LOG_LEVEL=INFO

# Bot:
# DATABASE_URL=postgresql://prod_rob_bot:<password>@<host>:<port>/rob_prod?sslmode=require
#
# Webhook:
# DATABASE_URL=postgresql://prod_rob_webhook:<password>@<host>:<port>/rob_prod?sslmode=require
#
# Rehearsal (bot):
# DATABASE_URL=postgresql://prod_rob_bot:<password>@<host>:<port>/rob_dev_v2?sslmode=require
#
# Rehearsal (webhook):
# DATABASE_URL=postgresql://prod_rob_webhook:<password>@<host>:<port>/rob_dev_v2?sslmode=require
DATABASE_URL=

DISCORD_TOKEN=
BOT_NAME=Rob

ROB_OPS_HOST=127.0.0.1
ROB_OPS_PORT=8811
ROB_OPS_SECRET=
# Webhook-only: POST recorded sends to the bot ops bridge for immediate Discord posting.
# Use the same ROB_OPS_SECRET value on both services when this is set.
#
# Single host (bot + webhook on one machine, DB remote): the two services talk
# over loopback — bot ROB_OPS_HOST=127.0.0.1 and webhook
# ROB_BOT_NOTIFY_URL=http://127.0.0.1:8811/ops/sends/process with a shared
# ROB_OPS_SECRET. `rob fix-me` (deploy/scripts/fix-me.sh) sets all of this up.
# See docs/deployment-combined.md.
ROB_BOT_NOTIFY_URL=

THRONE_WEBHOOK_HOST=127.0.0.1
THRONE_WEBHOOK_PORT=8080
THRONE_WEBHOOK_BASE_URL=https://throne.robthebot.com
THRONE_WEBHOOK_REQUIRE_SIGNATURE=true
THRONE_PUBLIC_KEY_PEM=
THRONE_WEBHOOK_DEBUG_LOG_PAYLOAD=false
THRONE_WEBHOOK_TIMESTAMP_HEADER=X-Signature-Timestamp
THRONE_WEBHOOK_SIGNATURE_HEADER=X-Signature-Ed25519
THRONE_WEBHOOK_SIGNED_MESSAGE_FORMAT=timestamp_dot_body
THRONE_WEBHOOK_MAX_TIMESTAMP_SKEW_SECONDS=300

THRONE_PARSE_TEST_SENDS_AS_REAL_SENDS=false
THRONE_TEST_GIFTER_USERNAMES=marie_123
THRONE_TEST_SEND_LEADERBOARD_OWNER_USER_ID=

ROB_PUBLIC_BASE_URL=https://robthebot.com
LEADERBOARD_LIMIT=10
SEND_QUEUE_LOOP_SECONDS=10
PUBLIC_LEADERBOARD_CACHE_SECONDS=60

# Activity / inactive-role system (test guild for now). A verified member who
# goes INACTIVITY_INACTIVE_AFTER_DAYS without sending a message or interacting
# loses the Active role, gains the Inactive role, and starts the removal
# countdown (first notice now, final notice INACTIVITY_FINAL_NOTICE_DAYS before
# removal, kick after INACTIVITY_KICK_GRACE_DAYS). Unverified members are parked
# as inactive (no kick countdown) until they verify. Roles are configured per
# guild with `rob guild scan` / `rob guild set-role`. Activity is recorded on
# every message/reaction/interaction (and a returning member is reactivated
# immediately); the sweep that flags newly-inactive members runs on
# INACTIVITY_LOOP_MINUTES (default weekly = 10080) and on each restart.
INACTIVITY_ENABLED_DEFAULT=false
INACTIVITY_LOOP_MINUTES=10080
INACTIVITY_INACTIVE_AFTER_DAYS=7
INACTIVITY_KICK_GRACE_DAYS=14
INACTIVITY_BOOTSTRAP_GRACE_DAYS=21
INACTIVITY_FINAL_NOTICE_DAYS=7
INACTIVITY_OWNER_USER_ID=
INACTIVITY_NOTICE_CHANNEL_ID=

# Hourly server-backup system (test guild for now). Snapshots roles, channels,
# and server settings every SERVER_BACKUP_LOOP_MINUTES. Only a *batch* of
# SERVER_BACKUP_MAJOR_CHANGE_THRESHOLD or more "major" changes (deletions,
# permission changes, structural changes) at once pauses backups and posts an
# approval prompt to the configured channel; a single addition or permission
# tweak is adopted silently. Backups resume once SERVER_BACKUP_REQUIRED_APPROVALS
# distinct moderators approve.
SERVER_BACKUP_ENABLED_DEFAULT=false
SERVER_BACKUP_LOOP_MINUTES=60
SERVER_BACKUP_REQUIRED_APPROVALS=2
SERVER_BACKUP_MAJOR_CHANGE_THRESHOLD=5

# TL;DR (/tldr) chat summariser. Available to everyone, scoped to the main + test
# guilds. Rob always builds an in-house extractive digest (participants, links,
# highlights, topic matches). If a local Ollama server (https://ollama.com) is
# reachable at TLDR_OLLAMA_URL with TLDR_MODEL pulled, that digest is upgraded to
# a natural-language summary — the chat is sent only to that local model, never
# off-host. If Ollama is unreachable Rob silently uses the digest. Leave
# TLDR_OLLAMA_URL blank to force the digest-only path. Set up the model with e.g.
# `ollama pull llama3.2:1b`.
#
# The model must fit in FREE RAM (CPU inference): llama3.2:1b needs ~1.3-1.6 GB.
# On a small host, check `free -h` and use a smaller model instead, e.g.
# `qwen2.5:0.5b` (~0.7-1 GB) or `smollm2:360m` (~0.4-0.6 GB); if it doesn't fit,
# Ollama returns HTTP 500 and Rob falls back to the digest. See
# docs/tldr-and-voice-transcription.md ("Right-sizing the model to the host's RAM").
TLDR_ENABLED=true
TLDR_OLLAMA_URL=http://127.0.0.1:11434
TLDR_MODEL=llama3.2:1b
# Total per-summary timeout. Rob pre-warms the model at startup so user calls
# shouldn't hit a cold load; TLDR_KEEP_ALIVE keeps the model resident between
# calls (Ollama duration string). On a dedicated host set TLDR_KEEP_ALIVE=-1m
# (negative = never unload) so no call is ever cold.
TLDR_REQUEST_TIMEOUT_SECONDS=120
TLDR_KEEP_ALIVE=10m
TLDR_MAX_MESSAGES=400
TLDR_COOLDOWN_SECONDS=30

# Voice-message speech-to-text. When enabled, Rob transcribes every voice message
# it sees and replies (without pinging) with the transcript. Uses a local
# faster-whisper model on CPU — nothing leaves the host. Requires the optional
# dependency: `pip install -r requirements-voice.txt`. The model is downloaded
# from Hugging Face on first use. Models: tiny/base/small/medium/large-v3
# (bigger = more accurate + slower). compute_type int8 is the fastest on CPU.
# Leave VOICE_TRANSCRIBE_LANGUAGE blank to auto-detect.
VOICE_TRANSCRIBE_ENABLED=false
VOICE_TRANSCRIBE_MODEL=base
VOICE_TRANSCRIBE_DEVICE=cpu
VOICE_TRANSCRIBE_COMPUTE_TYPE=int8
VOICE_TRANSCRIBE_LANGUAGE=
VOICE_TRANSCRIBE_DOWNLOAD_ROOT=
VOICE_TRANSCRIBE_BEAM_SIZE=1
VOICE_TRANSCRIBE_MAX_DURATION_SECONDS=300
VOICE_TRANSCRIBE_MAX_FILE_MB=25
VOICE_TRANSCRIBE_MAX_CONCURRENCY=1
