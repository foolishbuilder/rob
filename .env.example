APP_ENV=prod
LOG_LEVEL=INFO

# Bot:
# DATABASE_URL=postgresql://prod_rob_bot:<password>@<host>:<port>/rob_prod?sslmode=require
#
# Webhook:
# DATABASE_URL=postgresql://prod_rob_webhook:<password>@<host>:<port>/rob_prod?sslmode=require
#
# Rehearsal (bot):
# DATABASE_URL=postgresql://prod_rob_bot:<password>@<host>:<port>/rob_dev_v2?sslmode=require
#
# Rehearsal (webhook):
# DATABASE_URL=postgresql://prod_rob_webhook:<password>@<host>:<port>/rob_dev_v2?sslmode=require
DATABASE_URL=

DISCORD_TOKEN=
BOT_NAME=Rob

ROB_OPS_HOST=127.0.0.1
ROB_OPS_PORT=8811
ROB_OPS_SECRET=
# Webhook-only: POST recorded sends to the bot ops bridge for immediate Discord posting.
# Use the same ROB_OPS_SECRET value on both services when this is set.
#
# Single host (bot + webhook on one machine, DB remote): the two services talk
# over loopback — bot ROB_OPS_HOST=127.0.0.1 and webhook
# ROB_BOT_NOTIFY_URL=http://127.0.0.1:8811/ops/sends/process with a shared
# ROB_OPS_SECRET. `rob fix-me` (deploy/scripts/fix-me.sh) sets all of this up.
# See docs/deployment-combined.md.
ROB_BOT_NOTIFY_URL=

THRONE_WEBHOOK_HOST=127.0.0.1
THRONE_WEBHOOK_PORT=8080
THRONE_WEBHOOK_BASE_URL=https://throne.robthebot.com
THRONE_WEBHOOK_REQUIRE_SIGNATURE=true
THRONE_PUBLIC_KEY_PEM=
THRONE_WEBHOOK_DEBUG_LOG_PAYLOAD=false
THRONE_WEBHOOK_TIMESTAMP_HEADER=X-Signature-Timestamp
THRONE_WEBHOOK_SIGNATURE_HEADER=X-Signature-Ed25519
THRONE_WEBHOOK_SIGNED_MESSAGE_FORMAT=timestamp_dot_body
THRONE_WEBHOOK_MAX_TIMESTAMP_SKEW_SECONDS=300

THRONE_PARSE_TEST_SENDS_AS_REAL_SENDS=false
THRONE_TEST_GIFTER_USERNAMES=marie_123
THRONE_TEST_SEND_LEADERBOARD_OWNER_USER_ID=

ROB_PUBLIC_BASE_URL=https://robthebot.com
LEADERBOARD_LIMIT=10
SEND_QUEUE_LOOP_SECONDS=10
PUBLIC_LEADERBOARD_CACHE_SECONDS=60

# Activity / inactive-role system (test guild for now). A verified member who
# goes INACTIVITY_INACTIVE_AFTER_DAYS without sending a message or interacting
# loses the Active role, gains the Inactive role, and starts the removal
# countdown (first notice now, final notice INACTIVITY_FINAL_NOTICE_DAYS before
# removal, kick after INACTIVITY_KICK_GRACE_DAYS). Unverified members are parked
# as inactive (no kick countdown) until they verify. Roles are configured per
# guild with `rob guild scan` / `rob guild set-role`.
INACTIVITY_ENABLED_DEFAULT=false
INACTIVITY_LOOP_MINUTES=60
INACTIVITY_INACTIVE_AFTER_DAYS=7
INACTIVITY_KICK_GRACE_DAYS=14
INACTIVITY_BOOTSTRAP_GRACE_DAYS=21
INACTIVITY_FINAL_NOTICE_DAYS=7
INACTIVITY_OWNER_USER_ID=
INACTIVITY_NOTICE_CHANNEL_ID=

# Hourly server-backup system (test guild for now). Snapshots roles, channels,
# and server settings every SERVER_BACKUP_LOOP_MINUTES. A "major" change
# (deletions, permission changes, or structural changes) pauses backups and
# posts an approval prompt to the configured backup approval channel; backups
# resume once SERVER_BACKUP_REQUIRED_APPROVALS distinct moderators approve.
SERVER_BACKUP_ENABLED_DEFAULT=false
SERVER_BACKUP_LOOP_MINUTES=60
SERVER_BACKUP_REQUIRED_APPROVALS=2
