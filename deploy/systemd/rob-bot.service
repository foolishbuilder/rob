[Unit]
Description=Rob Discord Bot Service
# ollama.service ordering is a hint for hosts running the local TL;DR model;
# harmless on hosts without Ollama installed.
After=network.target ollama.service

[Service]
Type=simple
User=rob
Group=rob
WorkingDirectory=/opt/rob-bot/app
EnvironmentFile=/opt/rob-bot/app/.env
Environment=PYTHONPATH=/opt/rob-bot/app
ExecStart=/opt/rob-bot/app/.venv/bin/python -m apps.bot.main
Restart=always
RestartSec=5

# --- sandboxing / hardening ---
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=full
ProtectHome=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
CapabilityBoundingSet=
LockPersonality=true
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
